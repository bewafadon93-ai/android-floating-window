<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFF5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Floating Window Demo"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FF1A73E8"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap Start to launch the overlay.\nIt will appear on top of all apps."
        android:textSize="14sp"
        android:textColor="#FF757575"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btn_start_service"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="Start Floating Window"
        android:textColor="#FFFFFFFF"
        android:backgroundTint="#FF1A73E8"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_stop_service"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="Stop Floating Window"
        android:textColor="#FFFFFFFF"
        android:backgroundTint="#FFCC0000" />

</LinearLayout>
